{
	"name": "obsidian-ai-attachmate",
	"version": "1.0.1",
	"description": "Transcribes your PDFs, images, and Canvas files into searchable Markdown notes using AI.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"test": "vitest run --watch=false --silent --reporter=verbose",
		"prettier": "prettier --write \"src/**/*\" \"test/**/*\"",
		"lint": "eslint \"src/**/*\" \"test/**/*\"",
		"build-and-install": "node scripts/build-and-install.mjs",
		"release": "node scripts/release.mjs"
	},
	"keywords": [],
	"author": "",
	"license": "AGPL-3.0",
	"devDependencies": {
		"@cycraft/eslint": "^0.4.4",
		"@types/micromatch": "^4.0.10",
		"@types/node": "^20.19.37",
		"builtin-modules": "^3.3.0",
		"dotenv": "^16.6.1",
		"esbuild": "^0.27.4",
		"obsidian": "^1.12.3",
		"tslib": "^2.8.1",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"micromatch": "^4.0.8",
		"tesseract.js": "^5.1.1"
	}
}
