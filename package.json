		"@types/micromatch": "^4.0.10",
		"@types/node": "^20.19.37",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"builtin-modules": "^3.3.0",
		"dotenv": "^16.6.1",
		"esbuild": "^0.27.4",
		"obsidian": "^1.12.3",
		"tslib": "^2.8.1",
		"typescript": "^5.9.3",
		"vitest": "^3.2.4"
	},
	"dependencies": {
		"@google/generative-ai": "^0.24.1",
		"micromatch": "^4.0.8",
		"tesseract.js": "^5.1.1"
	}
